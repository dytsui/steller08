{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "steller08",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-13",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "steller08",
      "database_id": "8bbc5d33-d25d-43d7-86d7-648b635b95ce"
    }
  ],
  "r2_buckets": [
    {
      "binding": "VIDEOS",
      "bucket_name": "steller08-videos"
    },
    {
      "binding": "KEYFRAMES",
      "bucket_name": "steller08-keyframes"
    },
    {
      "binding": "SHARES",
      "bucket_name": "steller08-shares"
    },
    {
      "binding": "EXPORTS",
      "bucket_name": "steller08-exports"
    }
  ],
  "vars": {
    "NEXT_PUBLIC_APP_URL": "https://steller08.b384001.workers.dev",
    "NEXT_PUBLIC_DEFAULT_LOCALE": "zh-CN",
    "NEWS_API_BASE": "https://r.jina.ai/http://news.google.com/rss/search?q=高尔夫&hl=zh-CN&gl=CN&ceid=CN:zh-Hans",
    "ANALYZER_BASE_URL": "https://steller08-analyzer.onrender.com",
    "GEMINI_MODEL": "gemini-2.5-flash-lite",
    "GEMINI_API_BASE": "https://generativelanguage.googleapis.com/v1beta"
  },
  "observability": {
    "enabled": true
  }
}
